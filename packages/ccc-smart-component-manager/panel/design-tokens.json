      }
    },

    "semantic": {
      "background": {
        "primary": "#12141a",
        "secondary": "#171a22",
        "tertiary": "#1e2230",
        "elevated": "#252a3a",
        "overlay": "rgba(8, 10, 18, 0.6)"
      },
      "text": {
        "primary": "#e2e8f4",
        "secondary": "#a0aec4",
        "muted": "#5c6a82",
        "inverse": "#12141a",
        "link": "#5cc4ff"
      },
      "border": {
        "default": "#2a3042",
        "subtle": "#1e2230",
        "strong": "#3a4460",
        "focus": "#5ba8ff"
      },
      "accent": {
        "primary": "#5ba8ff",
        "primaryHover": "#74b8ff",
        "primaryActive": "#3d8ee6"
      },
      "success": "#50e3a4",
      "warning": "#e8b83d",
      "error": "#f45b6b",
      "info": "#5cc4ff"
    },

    "component": {
      "favorite": {
        "text": "#ffb347",
        "background": "rgba(255, 179, 71, 0.10)",
        "backgroundHover": "rgba(255, 179, 71, 0.18)",
        "border": "rgba(255, 179, 71, 0.25)"
      },
      "frequent": {
        "text": "#50e3a4",
        "background": "rgba(80, 227, 164, 0.10)",
        "backgroundHover": "rgba(80, 227, 164, 0.18)",
        "border": "rgba(80, 227, 164, 0.25)"
      },
      "normal": {
        "text": "#8896b0",
        "background": "rgba(136, 150, 176, 0.06)",
        "backgroundHover": "rgba(136, 150, 176, 0.12)",
        "border": "rgba(136, 150, 176, 0.15)"
      }
    },

    "interactive": {
      "hover": {
        "background": "#1e2436",
        "text": "#e2e8f4",
        "border": "#3a4460"
      },
      "active": {
        "background": "#283048",
        "text": "#ffffff",
        "border": "#5ba8ff"
      },
      "focus": {
        "outline": "#5ba8ff",
        "outlineWidth": "1px",
        "outlineOffset": "-1px"
      },
      "disabled": {
        "background": "#1a1e28",
        "text": "#3e4860",
        "border": "#252a3a",
        "opacity": "0.5"
      }
    }
  },

  "typography": {
    "fontFamily": {
      "ui": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif",
      "mono": "'SF Mono', Monaco, 'Cascadia Code', 'Roboto Mono', Consolas, 'Courier New', monospace"
    },
    "fontSize": {
      "xs": "10px",
      "sm": "11px",
      "base": "12px",
      "md": "13px",
      "lg": "14px",
      "xl": "16px"
    },
    "fontWeight": {
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.2,
      "normal": 1.4,
      "relaxed": 1.6
    },
    "letterSpacing": {
      "tight": "-0.01em",
      "normal": "0",
      "wide": "0.02em"
    }
  },

  "spacing": {
    "0": "0px",
    "0.5": "2px",
    "1": "4px",
    "1.5": "6px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "8": "32px"
  },

  "radii": {
    "none": "0",
    "sm": "3px",
    "md": "5px",
    "lg": "8px",
    "xl": "12px",
    "full": "9999px"
  },

  "shadows": {
    "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.3)",
    "md": "0 2px 6px -1px rgba(0, 0, 0, 0.4), 0 1px 3px -1px rgba(0, 0, 0, 0.3)",
    "lg": "0 6px 14px -3px rgba(0, 0, 0, 0.5), 0 3px 6px -2px rgba(0, 0, 0, 0.35)",
    "inset": "inset 0 1px 2px 0 rgba(0, 0, 0, 0.3)",
    "none": "none"
  },

  "transitions": {
    "fast": {
      "duration": "100ms",
      "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "normal": {
      "duration": "150ms",
      "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "slow": {
      "duration": "250ms",
      "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "easing": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "easeIn": "cubic-bezier(0.4, 0, 1, 1)",
      "easeOut": "cubic-bezier(0, 0, 0.2, 1)",
      "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    }
  },

