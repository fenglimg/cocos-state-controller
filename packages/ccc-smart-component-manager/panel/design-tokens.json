  "components": {
    "button": {
      "base": {
        "fontFamily": "var(--font-ui)",
        "fontSize": "var(--font-size-base)",
        "fontWeight": 500,
        "lineHeight": 1.2,
        "borderRadius": "var(--radius-md)",
        "padding": "var(--spacing-1) var(--spacing-2)",
        "cursor": "pointer",
        "transition": "background var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast)"
      },
      "variants": {
        "primary": {
          "default": {
            "background": "#5ba8ff",
            "color": "#ffffff",
            "border": "1px solid transparent"
          },
          "hover": {
            "background": "#74b8ff"
          },
          "active": {
            "background": "#3d8ee6"
          },
          "focus": {
            "outline": "1px solid #5ba8ff",
            "outlineOffset": "2px"
          },
          "disabled": {
            "background": "#252a3a",
            "color": "#3e4860",
            "cursor": "not-allowed"
          }
        },
        "secondary": {
          "default": {
            "background": "#252a3a",
            "color": "#e2e8f4",
            "border": "1px solid #2a3042"
          },
          "hover": {
            "background": "#2a3042",
            "borderColor": "#3a4460"
          },
          "active": {
            "background": "#283048"
          },
          "disabled": {
            "background": "#1a1e28",
            "color": "#3e4860"
          }
        },
        "ghost": {
          "default": {
            "background": "transparent",
            "color": "#a0aec4",
            "border": "1px solid transparent"
          },
          "hover": {
            "background": "#1e2436",
            "color": "#e2e8f4"
          },
          "active": {
            "background": "#283048"
          },
          "disabled": {
            "color": "#3e4860"
          }
        },
        "danger": {
          "default": {
            "background": "transparent",
            "color": "#f45b6b",
            "border": "1px solid rgba(244, 91, 107, 0.3)"
          },
          "hover": {
            "background": "rgba(244, 91, 107, 0.12)",
            "borderColor": "rgba(244, 91, 107, 0.5)"
          },
          "active": {
            "background": "rgba(244, 91, 107, 0.2)"
          },
          "disabled": {
            "color": "#3e4860",
            "borderColor": "#252a3a"
          }
        }
      }
    },

    "input": {
      "base": {
        "fontFamily": "var(--font-ui)",
        "fontSize": "var(--font-size-base)",
        "lineHeight": 1.4,
        "borderRadius": "var(--radius-sm)",
        "padding": "var(--spacing-1) var(--spacing-2)",
        "transition": "border-color var(--transition-fast), background var(--transition-fast)"
      },
      "default": {
        "background": "#252a3a",
        "color": "#e2e8f4",
        "border": "1px solid #2a3042",
        "placeholder": "#5c6a82"
      },
      "hover": {
        "borderColor": "#3a4460"
      },
      "focus": {
        "borderColor": "#5ba8ff",
        "outline": "none"
      },
      "disabled": {
        "background": "#1a1e28",
        "color": "#3e4860",
        "cursor": "not-allowed"
      },
      "error": {
        "borderColor": "#f45b6b"
      }
    },

    "card": {
      "base": {
        "borderRadius": "var(--radius-md)",
        "padding": "var(--spacing-3)",
        "transition": "background var(--transition-fast), border-color var(--transition-fast)"
      },
      "default": {
        "background": "#171a22",
        "border": "1px solid #2a3042"
      },
      "hover": {
        "background": "#1e2436",
        "borderColor": "#3a4460"
      },
      "active": {
        "background": "#283048",
        "borderColor": "#5ba8ff"
      }
    },

    "badge": {
      "base": {
        "fontSize": "var(--font-size-xs)",
        "fontWeight": 600,
        "lineHeight": 1,
        "borderRadius": "var(--radius-full)",
        "padding": "2px 6px",
        "display": "inline-flex",
        "alignItems": "center"
      },
      "variants": {
        "default": {
          "background": "#252a3a",
          "color": "#a0aec4"
        },
        "primary": {
          "background": "rgba(91, 168, 255, 0.2)",
          "color": "#5cc4ff"
        },
        "success": {
          "background": "rgba(80, 227, 164, 0.15)",
          "color": "#50e3a4"
        },
        "warning": {
          "background": "rgba(232, 184, 61, 0.15)",
          "color": "#e8b83d"
        },
        "error": {
          "background": "rgba(244, 91, 107, 0.15)",
          "color": "#f45b6b"
        }
      }
    },

    "tag": {
      "base": {
        "fontSize": "var(--font-size-sm)",
        "fontWeight": 500,
        "lineHeight": 1.2,
        "borderRadius": "var(--radius-sm)",
        "padding": "2px 8px",
        "display": "inline-flex",
        "alignItems": "center",
        "gap": "4px"
      },
      "default": {
        "background": "#252a3a",
        "color": "#a0aec4",
        "border": "1px solid #2a3042"
      },
      "hover": {
        "background": "#2a3042",
        "borderColor": "#3a4460"
      },
      "removable": {
        "paddingRight": "4px"
      }
    },

    "sectionHeader": {
      "base": {
        "fontSize": "var(--font-size-sm)",
        "fontWeight": 600,
        "lineHeight": 1.2,
        "letterSpacing": "0.02em",
        "textTransform": "uppercase",
        "padding": "var(--spacing-1) 0",
        "display": "flex",
        "alignItems": "center",
        "gap": "var(--spacing-1.5)"
      },
      "default": {
        "color": "#a0aec4",
        "borderBottom": "1px solid #1e2230"
      },
      "icon": {
        "width": "14px",
        "height": "14px",
        "opacity": 0.7
      }
    }
  }
}
