{
  "$schema": "design-tokens",
  "$version": "1.0.0",
  "$description": "Design token system for ccc-smart-component-manager Cocos Creator extension panel",

  "themes": {
    "$description": "All 6 theme palettes. 'vibrant-dark' is the default (no data-theme attribute). Others are activated via :host([data-theme='xxx'])",
    "available": ["vibrant-dark", "warm-dark", "cyberpunk", "forest", "sunset", "ocean"],
    "default": "vibrant-dark",

    "vibrant-dark": {
      "$description": "Default theme - deep blue-gray with electric blue accents",
      "accent": { "primary": "#5ba8ff", "primaryHover": "#74b8ff", "primaryActive": "#3d8ee6" },
      "status": { "success": "#50e3a4", "warning": "#e8b83d", "error": "#f45b6b", "info": "#5cc4ff" },
      "background": { "primary": "#12141a", "secondary": "#171a22", "tertiary": "#1e2230", "elevated": "#252a3a", "overlay": "rgba(8, 10, 18, 0.6)", "hover": "#1e2436", "active": "#283048", "card": "#171a22" },
      "text": { "primary": "#e2e8f4", "secondary": "#a0aec4", "muted": "#5c6a82", "inverse": "#12141a", "link": "#5cc4ff" },
      "border": { "default": "#2a3042", "subtle": "#1e2230", "strong": "#3a4460", "focus": "#5ba8ff" },
      "component": {
        "favorite": { "text": "#ffb347", "bg": "rgba(255, 179, 71, 0.10)", "bgHover": "rgba(255, 179, 71, 0.18)", "border": "rgba(255, 179, 71, 0.25)" },
        "frequent": { "text": "#50e3a4", "bg": "rgba(80, 227, 164, 0.10)", "bgHover": "rgba(80, 227, 164, 0.18)", "border": "rgba(80, 227, 164, 0.25)" },
        "normal": { "text": "#8896b0", "bg": "rgba(136, 150, 176, 0.06)", "bgHover": "rgba(136, 150, 176, 0.12)", "border": "rgba(136, 150, 176, 0.15)" }
      },
      "disabled": { "bg": "#1a1e28", "text": "#3e4860", "border": "#252a3a" }
    },

    "warm-dark": {
      "$description": "Warm dark theme - deep brown-gray with amber/caramel accents",
      "accent": { "primary": "#e8a64b", "primaryHover": "#f0b55a", "primaryActive": "#d4943e" },
      "status": { "success": "#6dbd8a", "warning": "#e8a64b", "error": "#e06060", "info": "#7cb8d4" },
      "background": { "primary": "#1c1816", "secondary": "#221d1a", "tertiary": "#2a2420", "elevated": "#342d27", "overlay": "rgba(16, 12, 10, 0.6)", "hover": "#2e2722", "active": "#3a322b", "card": "#221d1a" },
      "text": { "primary": "#e8ddd0", "secondary": "#b8a898", "muted": "#7a6e62", "inverse": "#1c1816", "link": "#e8a64b" },
      "border": { "default": "#3a332c", "subtle": "#2a2420", "strong": "#4e453c", "focus": "#e8a64b" },
      "component": {
        "favorite": { "text": "#e8a0a0", "bg": "rgba(232, 160, 160, 0.10)", "bgHover": "rgba(232, 160, 160, 0.18)", "border": "rgba(232, 160, 160, 0.25)" },
        "frequent": { "text": "#6dbd8a", "bg": "rgba(109, 189, 138, 0.10)", "bgHover": "rgba(109, 189, 138, 0.18)", "border": "rgba(109, 189, 138, 0.25)" },
        "normal": { "text": "#a89888", "bg": "rgba(168, 152, 136, 0.06)", "bgHover": "rgba(168, 152, 136, 0.12)", "border": "rgba(168, 152, 136, 0.15)" }
      },
      "disabled": { "bg": "#241f1b", "text": "#5a5048", "border": "#342d27" }
    },

    "cyberpunk": {
      "$description": "Cyberpunk theme - pure black with neon purple/pink accents and glow effects",
      "accent": { "primary": "#bf5af2", "primaryHover": "#d07af8", "primaryActive": "#a040d8" },
      "status": { "success": "#00f5d4", "warning": "#f0e030", "error": "#ff2d78", "info": "#00d4ff" },
      "background": { "primary": "#0a0a0f", "secondary": "#0f0f18", "tertiary": "#161622", "elevated": "#1e1e30", "overlay": "rgba(4, 4, 8, 0.7)", "hover": "#1a1a2e", "active": "#24243c", "card": "#0f0f18" },
      "text": { "primary": "#e0e0e8", "secondary": "#a0a0b8", "muted": "#5a5a72", "inverse": "#0a0a0f", "link": "#bf5af2" },
      "border": { "default": "#2a2a42", "subtle": "#1a1a2c", "strong": "#3c3c5e", "focus": "#bf5af2" },
      "component": {
        "favorite": { "text": "#f0e030", "bg": "rgba(240, 224, 48, 0.10)", "bgHover": "rgba(240, 224, 48, 0.18)", "border": "rgba(240, 224, 48, 0.25)" },
        "frequent": { "text": "#00f5d4", "bg": "rgba(0, 245, 212, 0.10)", "bgHover": "rgba(0, 245, 212, 0.18)", "border": "rgba(0, 245, 212, 0.25)" },
        "normal": { "text": "#7070a0", "bg": "rgba(112, 112, 160, 0.06)", "bgHover": "rgba(112, 112, 160, 0.12)", "border": "rgba(112, 112, 160, 0.15)" }
      },
      "disabled": { "bg": "#12121e", "text": "#404060", "border": "#1e1e30" },
      "special": { "glowShadow": "0 0 8px rgba(191, 90, 242, 0.3)" }
    },

    "forest": {
      "$description": "Forest theme - deep green-gray with emerald accents",
      "accent": { "primary": "#3fb68b", "primaryHover": "#4fcc9a", "primaryActive": "#32a07a" },
      "status": { "success": "#7dd87d", "warning": "#e8c84a", "error": "#e06060", "info": "#58b8d8" },
      "background": { "primary": "#141c17", "secondary": "#18221c", "tertiary": "#1e2a23", "elevated": "#26342b", "overlay": "rgba(10, 16, 12, 0.6)", "hover": "#1e2e24", "active": "#263a2d", "card": "#18221c" },
      "text": { "primary": "#d4e8dc", "secondary": "#98b8a6", "muted": "#587868", "inverse": "#141c17", "link": "#4fcc9a" },
      "border": { "default": "#2a3c30", "subtle": "#1e2a23", "strong": "#3a5244", "focus": "#3fb68b" },
      "component": {
        "favorite": { "text": "#e8c84a", "bg": "rgba(232, 200, 74, 0.10)", "bgHover": "rgba(232, 200, 74, 0.18)", "border": "rgba(232, 200, 74, 0.25)" },
        "frequent": { "text": "#7dd87d", "bg": "rgba(125, 216, 125, 0.10)", "bgHover": "rgba(125, 216, 125, 0.18)", "border": "rgba(125, 216, 125, 0.25)" },
        "normal": { "text": "#7a9888", "bg": "rgba(122, 152, 136, 0.06)", "bgHover": "rgba(122, 152, 136, 0.12)", "border": "rgba(122, 152, 136, 0.15)" }
      },
      "disabled": { "bg": "#1a241e", "text": "#3e5848", "border": "#26342b" }
    },

    "sunset": {
      "$description": "Sunset theme - warm dark with sunset orange accents",
      "accent": { "primary": "#f06449", "primaryHover": "#f47a64", "primaryActive": "#e85d3a" },
      "status": { "success": "#6dbd8a", "warning": "#d4a837", "error": "#e84a6f", "info": "#68b0d8" },
      "background": { "primary": "#181416", "secondary": "#1e1a1c", "tertiary": "#282224", "elevated": "#322a2c", "overlay": "rgba(12, 8, 10, 0.6)", "hover": "#2c2226", "active": "#3a2e32", "card": "#1e1a1c" },
      "text": { "primary": "#ede4db", "secondary": "#b8a8a0", "muted": "#786860", "inverse": "#181416", "link": "#f06449" },
      "border": { "default": "#3a2e32", "subtle": "#282224", "strong": "#50404a", "focus": "#f06449" },
      "component": {
        "favorite": { "text": "#e84a6f", "bg": "rgba(232, 74, 111, 0.10)", "bgHover": "rgba(232, 74, 111, 0.18)", "border": "rgba(232, 74, 111, 0.25)" },
        "frequent": { "text": "#d4a837", "bg": "rgba(212, 168, 55, 0.10)", "bgHover": "rgba(212, 168, 55, 0.18)", "border": "rgba(212, 168, 55, 0.25)" },
        "normal": { "text": "#a89090", "bg": "rgba(168, 144, 144, 0.06)", "bgHover": "rgba(168, 144, 144, 0.12)", "border": "rgba(168, 144, 144, 0.15)" }
      },
      "disabled": { "bg": "#201a1c", "text": "#584848", "border": "#322a2c" }
    },

    "ocean": {
      "$description": "Ocean theme - deep sea blue with teal/cyan accents",
      "accent": { "primary": "#20c9b0", "primaryHover": "#2bd4ba", "primaryActive": "#18b8a0" },
      "status": { "success": "#4dd0a0", "warning": "#e0b040", "error": "#f06070", "info": "#48b8e8" },
      "background": { "primary": "#101820", "secondary": "#141e28", "tertiary": "#1a2838", "elevated": "#223248", "overlay": "rgba(6, 10, 16, 0.6)", "hover": "#1a2c40", "active": "#223850", "card": "#141e28" },
      "text": { "primary": "#d0e4ed", "secondary": "#90b0c8", "muted": "#507088", "inverse": "#101820", "link": "#2bd4ba" },
      "border": { "default": "#243848", "subtle": "#1a2838", "strong": "#324c62", "focus": "#20c9b0" },
      "component": {
        "favorite": { "text": "#ff8a80", "bg": "rgba(255, 138, 128, 0.10)", "bgHover": "rgba(255, 138, 128, 0.18)", "border": "rgba(255, 138, 128, 0.25)" },
        "frequent": { "text": "#4dd0a0", "bg": "rgba(77, 208, 160, 0.10)", "bgHover": "rgba(77, 208, 160, 0.18)", "border": "rgba(77, 208, 160, 0.25)" },
        "normal": { "text": "#7898b0", "bg": "rgba(120, 152, 176, 0.06)", "bgHover": "rgba(120, 152, 176, 0.12)", "border": "rgba(120, 152, 176, 0.15)" }
      },
      "disabled": { "bg": "#142028", "text": "#385060", "border": "#223248" }
    }
  },

  "colors": {
    "$description": "Default color tokens (vibrant-dark theme). See 'themes' for all theme palettes.",
