      "gray": {
        "50": "#f8fafc",
        "100": "#f1f5f9",
        "200": "#e2e8f0",
        "300": "#cbd5e1",
        "400": "#94a3b8",
        "500": "#64748b",
        "600": "#475569",
        "700": "#334155",
        "800": "#1e293b",
        "900": "#0f172a",
        "950": "#020617"
      },
      "blue": {
        "400": "#74b8ff",
        "500": "#5ba8ff",
        "600": "#3d8ee6",
        "700": "#2a6fc0"
      },
      "green": {
        "400": "#6eedb8",
        "500": "#50e3a4",
        "600": "#38c88a"
      },
      "amber": {
        "400": "#ffc46a",
        "500": "#ffb347",
        "600": "#e89e30"
      },
      "red": {
        "400": "#f87a88",
        "500": "#f45b6b",
