        "i18n:MAIN_MENU.package.title/State Controller V2 Panel/关闭面板": {
            "message": "state-controller-v2-panel:close"
        },
        "i18n:MAIN_MENU.package.title/State Controller V2 Panel/Inspector 增强：开启": {
            "message": "state-controller-v2-panel:inspector-mark-on"
        },
        "i18n:MAIN_MENU.package.title/State Controller V2 Panel/Inspector 增强：关闭": {
            "message": "state-controller-v2-panel:inspector-mark-off"
        }
    },
    "panel": {
        "main": "panel/build.js",
        "type": "dockable",
        "title": "State Controller V2",
        "width": 480,
