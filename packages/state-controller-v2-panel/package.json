{
    "name": "state-controller-v2-panel",
    "version": "0.1.0",
    "description": "State Controller V2 编辑器面板 - 替代 cocos 2.x Inspector 死磕的极简扩展面板",
    "author": "wepie",
    "main": "main.js",
    "main-menu": {
        "i18n:MAIN_MENU.package.title/State Controller V2 Panel/打开面板": {
            "message": "state-controller-v2-panel:open"
